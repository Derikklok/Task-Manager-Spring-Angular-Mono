# .env.properties
# Copy this to project root and update with your actual values
# File location: C:\Users\User\Desktop\Task Manager\backend\.env.properties

#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SERVER CONFIGURATION
#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Server port (default: 8080)
PORT=8080

#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE CONFIGURATION
#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# MySQL Database URL
# Format: jdbc:mysql://host:port/database_name
# Examples:
#   Local: jdbc:mysql://localhost:3306/task_manager
#   Remote: jdbc:mysql://your-db-server.com:3306/task_manager
DB_URL=jdbc:mysql://localhost:3306/task_manager

# MySQL Database Username
# Default for local MySQL: root
DB_USERNAME=root

# MySQL Database Password
# Change this to your MySQL root password or database user password
DB_PASSWORD=your_mysql_password_here

#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT CONFIGURATION
#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT Secret Key
# ⚠️ IMPORTANT:
#   - Must be at least 32 characters long for HS256 algorithm
#   - Must be kept SECRET in production
#   - Use a strong random string
#   - Never commit to git (this file should be in .gitignore)
#
# Generate a secure key:
#   Option 1: Use an online generator (https://www.random.org/strings/)
#   Option 2: Use OpenSSL: openssl rand -base64 32
#   Option 3: Use Java: java -cp . -Dkey=$(openssl rand -base64 32) YourApp
#
# Example (DO NOT USE THIS IN PRODUCTION):
JWT_SECRET=your_32_character_minimum_secret_key_should_be_very_long_and_random

# JWT Token Expiration Time (in milliseconds)
# 86400000 = 24 hours (default)
# 3600000 = 1 hour
# 604800000 = 7 days
# 2592000000 = 30 days
#
# Set based on your security requirements:
#   - Shorter expiration = More secure but frequent re-login
#   - Longer expiration = Less secure but better user experience
JWT_EXP=86400000

#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PRODUCTION CHECKLIST
#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Before deploying to production:
# ✓ Replace 'localhost' with actual database server
# ✓ Use strong, randomly generated JWT_SECRET
# ✓ Set JWT_EXP appropriately (shorter is more secure)
# ✓ Use environment-specific database
# ✓ Add .env.properties to .gitignore
# ✓ Store actual secrets in secure vault/environment variables
# ✓ Use HTTPS for all API calls
# ✓ Implement rate limiting on auth endpoints
# ✓ Enable audit logging
# ✓ Set up monitoring and alerting

#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EXAMPLE CONFIGURATIONS
#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# LOCAL DEVELOPMENT
# ────────────────
# PORT=8080
# DB_URL=jdbc:mysql://localhost:3306/task_manager
# DB_USERNAME=root
# DB_PASSWORD=root
# JWT_SECRET=devSecretKeyThatIsAtLeast32CharsLongForTesting123456
# JWT_EXP=86400000


# STAGING
# ───────
# PORT=8080
# DB_URL=jdbc:mysql://staging-db.internal:3306/task_manager_staging
# DB_USERNAME=staging_user
# DB_PASSWORD=<use_vault_or_env_variable>
# JWT_SECRET=<use_vault_or_env_variable>
# JWT_EXP=3600000


# PRODUCTION
# ──────────
# PORT=8080
# DB_URL=jdbc:mysql://prod-db.internal:3306/task_manager_prod
# DB_USERNAME=<use_vault_or_env_variable>
# DB_PASSWORD=<use_vault_or_env_variable>
# JWT_SECRET=<use_vault_or_env_variable>
# JWT_EXP=3600000

#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECURITY RECOMMENDATIONS
#━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1. ADD TO .gitignore
#    Add the following line to your .gitignore:
#    .env.properties
#
# 2. SECRET MANAGEMENT IN PRODUCTION
#    - Use AWS Secrets Manager
#    - Use Azure Key Vault
#    - Use HashiCorp Vault
#    - Use Kubernetes Secrets
#    - Never commit secrets to git
#
# 3. ENVIRONMENT VARIABLES
#    Instead of .env.properties, use actual environment variables:
#    export JWT_SECRET="your-secret-key"
#    export JWT_EXP="86400000"
#    export DB_URL="jdbc:mysql://..."
#
# 4. SECURE JWT_SECRET
#    Minimum 32 characters for HS256:
#    openssl rand -base64 32
#
# 5. ROTATE SECRETS REGULARLY
#    - Change JWT_SECRET periodically
#    - Invalidate old tokens after rotation
#    - Use key versioning if possible


